<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+ granular media permission -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Older Android versions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- Only used if the user opts into the cleaning-reminder notification
         in Settings; requested at runtime on API 33+, never assumed. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- largeHeap kept as a backstop, not the fix. The actual OOM causes were
         a Coil bitmapConfig that was silently ignored (see MediaPreview.kt)
         and a prefetch that decoded/cached photos at a size the swipe card
         never asked for (see SwipeScreen.kt), both now fixed — plus a memory
         cache pinned to a fixed percentage in GalleryCleanerApp.kt so it
         doesn't just grow with this flag. Still worth leaving on for low-end
         devices, but it should no longer be load-bearing. -->
    <application
        android:name=".GalleryCleanerApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:theme="@style/Theme.GalleryCleaner">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.GalleryCleaner.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
    </application>
</manifest>
